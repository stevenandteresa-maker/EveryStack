# EveryStack — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# ─── Database (PostgreSQL via PgBouncer) ─────────────────────────────────────
# Primary connection through PgBouncer (transaction pooling) — used by the app
# PRODUCTION: Must include ?sslmode=require or ?sslmode=verify-full for TLS.
# The app will fail to start in production without TLS. See compliance.md § Encryption.
DATABASE_URL=postgresql://everystack:everystack_dev@localhost:6432/everystack_dev

# Direct connection bypassing PgBouncer — used for migrations and advisory locks
# PRODUCTION: Must include ?sslmode=require or ?sslmode=verify-full for TLS.
DATABASE_URL_DIRECT=postgresql://everystack:everystack_dev@localhost:5432/everystack_dev

# Read replica connection (same as primary in dev, separate in production)
# PRODUCTION: Must include ?sslmode=require or ?sslmode=verify-full for TLS.
DATABASE_READ_URL=postgresql://everystack:everystack_dev@localhost:6432/everystack_dev

# ─── Redis ────────────────────────────────────────────────────────────────────
# Used for caching, pub/sub (Socket.io adapter), and BullMQ job queues
# PRODUCTION: Must use rediss:// protocol (double-s) for TLS. See compliance.md § Encryption.
REDIS_URL=redis://localhost:6379

# ─── Auth (Clerk) ────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your application → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# ─── AI (Anthropic) ──────────────────────────────────────────────────────────
# Used by AIService abstraction — feature code never references this directly
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Transactional email for invites, portal magic links, notifications
RESEND_API_KEY=re_...

# ─── File Storage (Cloudflare R2) ────────────────────────────────────────────
# S3-compatible object storage for file attachments and document output
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=everystack-dev
R2_PUBLIC_URL=

# ─── PDF Generation (Gotenberg) ──────────────────────────────────────────────
# Sandboxed HTML-to-PDF conversion for Smart Docs
GOTENBERG_URL=http://localhost:3030

# ─── Billing (Stripe) ────────────────────────────────────────────────────────
# Subscription management and usage-based billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Observability (Sentry) ──────────────────────────────────────────────────
# Error tracking and performance monitoring
# DSN for server-side Sentry (web server, worker, edge)
SENTRY_DSN=
# DSN exposed to the browser (can be the same as SENTRY_DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source map uploads (only needed in CI/CD)
SENTRY_AUTH_TOKEN=
# Sentry organization slug
SENTRY_ORG=
# Sentry project slug
SENTRY_PROJECT=
# Environment tag: development | staging | production
SENTRY_ENVIRONMENT=development
# Public environment tag exposed to the browser
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development

# ─── Application ─────────────────────────────────────────────────────────────
# Public-facing app URL (used for OAuth callbacks, email links, CORS)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Socket.io realtime server port
REALTIME_PORT=3001

# Public URL for the Socket.io realtime server (used by the client)
NEXT_PUBLIC_REALTIME_URL=http://localhost:3002

# Node environment: development | test | production
NODE_ENV=development

# ─── Docker Compose Port Overrides (optional) ────────────────────────────────
# Uncomment to change default ports if they conflict with local services
# POSTGRES_PORT=5432
# PGBOUNCER_PORT=6432
# REDIS_PORT=6379
