{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "DATABASE_URL_DIRECT",
    "DATABASE_READ_URL",
    "REDIS_URL",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {},
    "check:i18n": {},
    "test": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "REDIS_URL"],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "vitest.config.ts"]
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "env": ["DATABASE_URL", "REDIS_URL"],
      "cache": false
    },
    "test:coverage-check": {
      "dependsOn": ["test"]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "env": ["PLAYWRIGHT_BASE_URL", "TEST_USER_EMAIL", "TEST_USER_PASSWORD"],
      "cache": false
    },
    "test:ai-eval": {
      "env": ["ANTHROPIC_API_KEY"],
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "db:migrate:check": {
      "cache": false,
      "dependsOn": ["db:migrate"]
    },
    "db:seed-staging": {
      "cache": false
    }
  }
}
