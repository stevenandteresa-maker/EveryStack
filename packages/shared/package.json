{
  "name": "@everystack/shared",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./auth": "./auth/index.ts",
    "./db": "./db/index.ts",
    "./sync": "./sync/index.ts",
    "./ai": "./ai/index.ts",
    "./testing": "./testing/index.ts",
    "./logging": "./logging/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint . --max-warnings 0",
    "check:i18n": "echo 'No i18n strings yet' && exit 0",
    "test": "vitest run",
    "test:coverage-check": "echo 'No coverage thresholds yet' && exit 0",
    "test:ai-eval": "echo 'No AI eval suite yet' && exit 0",
    "db:migrate": "drizzle-kit migrate --config db/drizzle.config.ts",
    "db:migrate:check": "echo 'No migration check yet' && exit 0",
    "db:generate": "drizzle-kit generate --config db/drizzle.config.ts",
    "db:seed-staging": "echo 'No staging seed yet' && exit 0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "uuidv7": "^1.1.0"
  }
}
