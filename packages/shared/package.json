{
  "name": "@everystack/shared",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./auth": "./auth/index.ts",
    "./db": "./db/index.ts",
    "./sync": "./sync/index.ts",
    "./ai": "./ai/index.ts",
    "./testing": "./testing/index.ts",
    "./logging": "./logging/index.ts",
    "./telemetry": "./telemetry/index.ts",
    "./errors": "./errors/index.ts",
    "./webhooks": "./webhooks/index.ts",
    "./compliance": "./compliance/index.ts",
    "./redis": "./redis/index.ts",
    "./realtime": "./realtime/index.ts",
    "./queue": "./queue/index.ts",
    "./storage": "./storage/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "lint": "eslint . --max-warnings 0",
    "check:i18n": "echo 'No i18n strings yet' && exit 0",
    "test": "vitest run",
    "test:coverage-check": "echo 'No coverage thresholds yet' && exit 0",
    "test:ai-eval": "echo 'No AI eval suite yet' && exit 0",
    "db:migrate": "drizzle-kit migrate --config db/drizzle.config.ts",
    "db:migrate:check": "echo 'No migration check yet' && exit 0",
    "db:generate": "drizzle-kit generate --config db/drizzle.config.ts",
    "db:seed-staging": "tsx db/scripts/seed-staging.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "msw": "^2.12.10",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-s3": "^3.1001.0",
    "@aws-sdk/s3-request-presigner": "^3.1001.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/resources": "^2.5.1",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "drizzle-orm": "^0.45.1",
    "ioredis": "^5.10.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.8",
    "svix": "^1.86.0",
    "uuidv7": "^1.1.0"
  }
}
