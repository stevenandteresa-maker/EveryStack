# EveryStack — Test Environment Variables
# Copy to .env.test and use with test runner: cp .env.test.example .env.test
# Ports are offset from dev stack (5434, 6433, 6380) so both can run simultaneously.

# ─── Database (PostgreSQL via PgBouncer) ─────────────────────────────────────
DATABASE_URL=postgresql://everystack_test:test_password@localhost:6433/everystack_test
DATABASE_URL_DIRECT=postgresql://everystack_test:test_password@localhost:5434/everystack_test

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ─── Auth (Clerk) ───────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxx

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=test
