{
  "name": "everystack",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check:i18n": "turbo run check:i18n",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:env:check": "bash scripts/test-env-check.sh",
    "test:env:up": "docker compose -f docker-compose.test.yml up -d --wait && pnpm test:env:check",
    "test:services:up": "docker compose -f docker-compose.test.yml up -d --wait",
    "test:services:down": "docker compose -f docker-compose.test.yml down"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-security": "^4.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2.8.17",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23"
  }
}
